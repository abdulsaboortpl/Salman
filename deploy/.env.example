# =============================================================================
# Copy to .env on your VPS and fill in the values
# cp .env.example .env
# =============================================================================

# GitHub Container Registry image prefix (lowercase)
# Example: ghcr.io/your-github-username
REGISTRY=ghcr.io/abdulsaboortpl

# Image tag to deploy (latest or commit SHA from GitHub Actions)
IMAGE_TAG=latest

# Public URL of your frontend (used for CORS)
# Example: http://123.45.67.89  or  https://auth.yourdomain.com
FRONTEND_URL=http://localhost

# Port exposed on the VPS host
HTTP_PORT=80

# -----------------------------------------------------------------------------
# SQL Server on VPS host (already running on localhost:1433)
# Do NOT change DB_HOST on VPS — host.docker.internal reaches the host machine
# from inside the Docker container.
# -----------------------------------------------------------------------------
DB_HOST=host.docker.internal
DB_PORT=1433
DB_NAME=SalmanDB
DB_USER=sa
DB_PASSWORD=YourStrong@Passw0rd

# JWT secret (min 32 characters — change in production!)
JWT_SECRET=YourSuperSecretKeyForJWT_MustBeAtLeast32Characters!

# Optional JWT settings
JWT_ISSUER=AuthAPI
JWT_AUDIENCE=AuthAPIClient
JWT_ACCESS_EXPIRY=60
JWT_REFRESH_EXPIRY=7

# Set to true to enable Swagger at /swagger via nginx proxy
ENABLE_SWAGGER=false

# =============================================================================
# SSH tunnel for local development (from your PC to VPS SQL Server):
#   ssh -L 14330:localhost:1433 user@your-vps-ip
# Then connect locally with:
#   Server=localhost,14330;Database=SalmanDB;User Id=sa;Password=...;
# =============================================================================
