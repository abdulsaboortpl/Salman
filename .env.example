# Copy to .env on VPS before deploy:  cp .env.example .env

REGISTRY=ghcr.io/abdulsaboortpl
IMAGE_TAG=latest

FRONTEND_URL=http://YOUR_VPS_IP
HTTP_PORT=80

# SQL Server on VPS host (NOT Docker) — port 1433
DB_HOST=host.docker.internal
DB_PORT=1433
DB_NAME=SalmanDB
DB_USER=sa
DB_PASSWORD=YourStrong@Passw0rd

JWT_SECRET=YourSuperSecretKeyForJWT_MustBeAtLeast32Characters!

ENABLE_SWAGGER=false
