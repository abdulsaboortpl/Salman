# =============================================================================
# VPS environment — copy to .env before docker compose up
# cp .env.example .env
# =============================================================================

IMAGE_TAG=latest
FRONTEND_URL=http://YOUR_VPS_IP
HTTP_PORT=80

# Your EXISTING SQL Server (already running on VPS port 1433)
# Use host.docker.internal when SQL is on the host or published to host :1433
# Use your SQL container name if both are on the same Docker network
DB_HOST=host.docker.internal
DB_PORT=1433
DB_NAME=SalmanDB
DB_USER=sa
DB_PASSWORD=YourStrong@Passw0rd

JWT_SECRET=YourSuperSecretKeyForJWT_MustBeAtLeast32Characters!
JWT_ISSUER=AuthAPI
JWT_AUDIENCE=AuthAPIClient
ENABLE_SWAGGER=false
