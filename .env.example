# =============================================================================
# VPS environment — copy to .env before docker compose up
# cp .env.example .env
# =============================================================================

IMAGE_TAG=latest
FRONTEND_URL=http://YOUR_VPS_IP:8080
HTTP_PORT=8080

# Existing SQL Server on VPS (do NOT stop it — app connects via host port 1433)
DB_HOST=host.docker.internal
DB_PORT=1433
DB_NAME=SalmanDB
DB_USER=sa
DB_PASSWORD=Salman@StrongPass123

JWT_SECRET=YourSuperSecretKeyForJWT_MustBeAtLeast32Characters!
JWT_ISSUER=AuthAPI
JWT_AUDIENCE=AuthAPIClient
ENABLE_SWAGGER=false
